# 의존성 (npm/yarn/pnpm으로 다시 설치 가능하므로 제외)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 테스트 결과물
/coverage

# Next.js 빌드 결과물 (빌드 시 자동 생성되므로 제외)
/.next/
/out/

# 프로덕션 빌드 (배포 시 자동 생성)
/build

# 디버그 로그 (자동 생성되는 임시 파일)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 환경 변수 (API 키 등 민감한 정보 보호)
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Vercel 배포 관련 파일
.vercel

# TypeScript 빌드 정보 (자동 생성됨)
*.tsbuildinfo
next-env.d.ts

# IDE 및 에디터 설정 (개인 환경 설정)
.vscode/
.idea/
*.swp
*.swo

# macOS 시스템 파일 (Finder가 자동 생성)
.DS_Store
*.pem

# 로그 파일
logs
*.log
